# Server
PORT=3000
# Public base URL of this app (used for the Paystack payment callback).
# In local dev this is usually http://localhost:3000
BASE_URL=http://localhost:3000

# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/naija_kitchen

# Session signing secret — change this to any long random string
SESSION_SECRET=replace_with_a_long_random_secret

# Paystack TEST keys — get them from https://dashboard.paystack.com/#/settings/developers
# Use the keys that start with sk_test_ and pk_test_
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
